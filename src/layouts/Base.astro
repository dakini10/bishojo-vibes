---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bishojo Vibes — 美少女Vibes',
  description = '美少女Vibes — Your vibe starts here.',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/mplus1p-900-subset.woff2" crossorigin />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bishojo-vibes.com" />
    <meta property="og:image" content="https://bishojo-vibes.com/images/og-image.webp" />
    <meta property="og:site_name" content="Bishojo Vibes" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
